{
  "name": "agent-orchestrator-kit",
  "version": "0.1.12",
  "description": "Universal AI agent orchestration kit for Cursor, Claude Code, and Amp Code — spec-driven OpenSpec pipeline, cross-IDE subagents, and optional local Figma PAT setup (figma-setup / figma-status / figma-fetch)",
  "keywords": [
    "ai-agent",
    "cursor",
    "claude-code",
    "amp-code",
    "openspec",
    "sdd",
    "agent-orchestration",
    "subagents",
    "custom-subagents",
    "design-to-code",
    "figma",
    "figma-mcp",
    "developer-tools"
  ],
  "author": "Maksim Shevyakov <makshc2>",
  "license": "MIT",
  "homepage": "https://github.com/makshc2/agent-orchestrator-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makshc2/agent-orchestrator-kit.git"
  },
  "bugs": {
    "url": "https://github.com/makshc2/agent-orchestrator-kit/issues"
  },
  "type": "module",
  "bin": {
    "agent-orchestrator-kit": "bin/agent-orchestrator.js",
    "agent-orchestrator": "bin/agent-orchestrator.js"
  },
  "files": [
    "bin/",
    "templates/",
    "profiles/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "picocolors": "^1.0.0"
  },
  "scripts": {
    "prepack": "chmod +x bin/agent-orchestrator.js",
    "prepublishOnly": "npm test",
    "test": "node --test test/*.test.js",
    "link": "npm link",
    "release:check": "npm test && npm pack --dry-run",
    "release:tag": "git tag v$(node -p \"require('./package.json').version\")"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1"
  }
}
