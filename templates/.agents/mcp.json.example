{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": ".cursor/memory.json"
      }
    },
    "figma": {
      "command": "node",
      "args": ["scripts/figma-mcp-launcher.cjs"]
    }
  }
}
